{
  "name": "liz-saas",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform for salon management",
  "type": "module",
  "main": "src/_worker.js",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:remote": "wrangler dev",
    "deploy": "wrangler deploy --env development",
    "deploy:prod": "wrangler deploy --env production",
    "deploy:dry": "wrangler deploy --dry-run",
    "db:migrate": "echo 'Execute migrations manually in Supabase Dashboard or via psql'",
    "db:seed": "echo 'Execute seed-demo.sql manually in Supabase Dashboard'",
    "test": "echo 'Integration tests coming soon'",
    "lint": "echo 'Linting configured in next phase'"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "salon",
    "scheduling"
  ],
  "author": "NewTrader Dev",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cloudflare/wrangler": "^3.0.0"
  }
}
